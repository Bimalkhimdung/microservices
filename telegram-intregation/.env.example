# ─── Environment ─────────────────────────────────────────────────────────────
PORT=3001

# API key that callers must supply as the `x-api-key` header
API_KEY=change-me-strong-secret-key

# Telegram Bot Token from @BotFather (required)
# Format: 123456789:ABCDefGhIJKlmNoPQRstuVWXyz
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Optional: Comma-separated list of Telegram user IDs allowed to send commands
# Leave empty to allow all users (open mode)
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Mode: polling (default, no public URL needed) or webhook
# For webhook mode also set WEBHOOK_URL and WEBHOOK_SECRET
BOT_MODE=polling

# WEBHOOK_URL=https://your-domain.com/telegram/webhook
# WEBHOOK_SECRET=random-secret-for-webhook-validation
