# ─── Environment ─────────────────────────────────────────────────────────────
PORT=3000

# API key that all callers must supply as the `x-api-key` header
API_KEY=change-me-strong-secret-key

# Directory where WhatsApp Baileys auth files are stored (creds.json, etc.)
# Use ./data/wa-auth for local dev, /data/wa-auth for Docker/Kubernetes
AUTH_DIR=./data/wa-auth

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Optional: account label (for multi-account support in future)
# WA_ACCOUNT_ID=default
